{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=../SyncApp26.Infrastructure/SyncApp26.db;Mode=ReadWrite"
  },
  "AllowedHosts": "*",
  "Frontend": {
    "LoginUrl": "http://localhost:4200/login"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "your-email@gmail.com",
    "Password": "your-smtp-app-password",
    "FromEmail": "syncapp@hr.com",
    "FromName": "SyncApp26",
    "EnableSsl": true
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY",
    "Issuer": "SyncApp26API",
    "Audience": "SyncApp26Client",
    "ExpirationMinutes": 60
  },
  "SignatureHmac": {
    "DevKey": "REPLACE_WITH_A_LONG_RANDOM_DEV_ONLY_KEY"
  }
}
